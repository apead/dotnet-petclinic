@inherits LayoutComponentBase

<nav class="navbar navbar-expand-lg navbar-dark petclinic-navbar" role="navigation">
    <div class="container-fluid">
        <a class="navbar-brand petclinic-brand" href="/">PetClinic</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#main-navbar">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="main-navbar">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="fa fa-home" aria-hidden="true"></span>
                        <span>Home</span>
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="owners/find">
                        <span class="fa fa-search" aria-hidden="true"></span>
                        <span>Find Owners</span>
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="vets">
                        <span class="fa fa-th-list" aria-hidden="true"></span>
                        <span>Veterinarians</span>
                    </NavLink>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container-fluid">
    <div class="container xd-container">
        @Body
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-12 text-center" style="margin-bottom: 40px;">
        <img src="/dotnet-logo.svg" alt="Powered by .NET" class="logo" />
        </div>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
